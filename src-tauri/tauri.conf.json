{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stremio Horizon",
  "version": "0.1.0",
  "identifier": "com.aqu1tain.stremio-horizon",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Stremio Horizon",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/stremio-service",
      "binaries/stremio-runtime",
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "resources": [
      "binaries/server.js",
      "binaries/package.json"
    ],
    "macOS": {
      "files": {
        "MacOS/server.js": "binaries/server.js",
        "MacOS/package.json": "binaries/package.json"
      }
    }
  }
}
